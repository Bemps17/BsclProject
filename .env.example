# BSCL Platform — PostgreSQL (Supabase or any Postgres provider)
# When DATABASE_URL and AUTH_SECRET are both unset, the app runs in demo mode
# (guest profile + queue stored in browser localStorage).
#
# Supabase: Project Settings → Database → Connection string (Transaction pooler, port 6543)
# Local migrations: use the direct connection (port 5432) in a separate env if needed.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# NextAuth (required for live / Standard mode on Vercel)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Optional locally; on Vercel use trustHost (see src/auth.ts) or set to your deployment URL
AUTH_URL="http://localhost:3000"

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Discord Bot (BSCL Matchmaker)
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
# Bot → web API (defaults to AUTH_URL)
BSCL_API_URL="http://localhost:3000"
# Optional override; defaults to DISCORD_BOT_TOKEN for /api/bot/* Bearer auth
BOT_API_SECRET=""

# Supabase (Realtime + Storage — optional until Phase 5–6 in docs/roadmap-comet.md)
# NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# Optional: S3-compatible storage for team logos (Cloudflare R2, etc.)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
