generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  CAPTAIN
  MODERATOR
  ADMIN
  OWNER
}

enum RankTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  ELITE
}

enum MatchStatus {
  DRAFT
  LIVE
  SUBMITTED
  CONFIRMED
  DISPUTED
  CANCELLED
}

enum TournamentFormat {
  SINGLE_ELIM
  DOUBLE_ELIM
}

enum BestOf {
  BO1
  BO3
  BO5
}

enum TournamentStatus {
  DRAFT
  OPEN
  CHECK_IN
  LIVE
  COMPLETED
  CANCELLED
}

enum TicketCategory {
  MATCH_DISPUTE
  PLAYER_REPORT
  TECHNICAL
  APPEAL
  GENERAL
}

enum TicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum SanctionType {
  BAN
  TEMP_BAN
  MUTE
  WARNING
}

enum NewsCategory {
  ANNOUNCEMENT
  PATCH_NOTES
  TOURNAMENT
  GENERAL
}

enum ServiceStatus {
  ONLINE
  DEGRADED
  OFFLINE
}

enum QueueStatus {
  WAITING
  DRAFTING
  MATCH_CREATED
  LEFT
}

model User {
  id            String    @id @default(cuid())
  discordId     String    @unique
  username      String
  discriminator String?
  avatar        String?
  email         String?
  role          UserRole  @default(PLAYER)
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  player        Player?
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[] @relation("AuditActor")
  tickets       Ticket[]   @relation("TicketCreator")
  assignedTickets Ticket[] @relation("TicketAssignee")
  sanctions     Sanction[] @relation("SanctionTarget")
  issuedSanctions Sanction[] @relation("SanctionIssuer")
  newsPosts     News[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Player {
  id                  String    @id @default(cuid())
  userId              String    @unique
  displayName         String
  elo                 Int       @default(1000)
  mmr                 Int       @default(1000)
  peakElo             Int       @default(1000)
  rank                RankTier  @default(SILVER)
  placementMatches    Int       @default(0)
  placementComplete   Boolean   @default(false)
  wins                Int       @default(0)
  losses              Int       @default(0)
  verified            Boolean   @default(false)
  teamId              String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                Team?     @relation(fields: [teamId], references: [id])
  captainOf           Team[]    @relation("TeamCaptain")
  coCaptainOf         Team[]    @relation("TeamCoCaptain")
  matchPlayers        MatchPlayer[]
  queueEntries        QueueEntry[]
  eloHistory          EloHistory[]
  sentInvitations     TeamInvitation[] @relation("InvitationSender")
  receivedInvitations TeamInvitation[] @relation("InvitationReceiver")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String   @unique @db.VarChar(4)
  logoUrl     String?
  captainId   String
  coCaptainId String?
  seasonId    String?
  wins        Int      @default(0)
  losses      Int      @default(0)
  recruiting  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  captain     Player   @relation("TeamCaptain", fields: [captainId], references: [id])
  coCaptain   Player?  @relation("TeamCoCaptain", fields: [coCaptainId], references: [id])
  season      Season?  @relation(fields: [seasonId], references: [id])
  members     Player[]
  invitations TeamInvitation[]
  matchTeams  MatchTeam[]
  tournaments TournamentTeam[]
}

model TeamInvitation {
  id         String   @id @default(cuid())
  teamId     String
  senderId   String
  receiverId String
  accepted   Boolean?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sender   Player @relation("InvitationSender", fields: [senderId], references: [id])
  receiver Player @relation("InvitationReceiver", fields: [receiverId], references: [id])

  @@unique([teamId, receiverId])
}

model Season {
  id        String   @id @default(cuid())
  number    Int      @unique
  name      String
  week      Int      @default(1)
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  teams   Team[]
  matches Match[]
}

model Match {
  id           String      @id @default(cuid())
  number       Int         @unique @default(autoincrement())
  seasonId     String?
  status       MatchStatus @default(DRAFT)
  alphaScore   Int?
  bravoScore   Int?
  draftOrder   Json?
  captainAlpha String?
  captainBravo String?
  submittedBy  String?
  confirmedBy  String?
  disputedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  season       Season?     @relation(fields: [seasonId], references: [id])
  teams        MatchTeam[]
  players      MatchPlayer[]
  tickets      Ticket[]
}

model MatchTeam {
  id      String @id @default(cuid())
  matchId String
  teamId  String?
  side    String // ALPHA | BRAVO
  name    String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team? @relation(fields: [teamId], references: [id])

  @@unique([matchId, side])
}

model MatchPlayer {
  id       String  @id @default(cuid())
  matchId  String
  playerId String
  side     String
  eloDelta Int?

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  format      TournamentFormat
  bestOf      BestOf
  status      TournamentStatus @default(DRAFT)
  prizePool   Int              @default(0)
  maxTeams    Int              @default(16)
  startsAt    DateTime
  checkInAt   DateTime?
  bracket     Json?
  winnerId    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  teams TournamentTeam[]
}

model TournamentTeam {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String
  checkedIn    Boolean  @default(false)
  seed         Int?
  eliminated   Boolean  @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}

model News {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String       @db.Text
  excerpt     String?
  category    NewsCategory @default(GENERAL)
  featured    Boolean      @default(false)
  published   Boolean      @default(false)
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model Sanction {
  id        String       @id @default(cuid())
  type      SanctionType
  reason    String
  targetId  String
  issuerId  String
  expiresAt DateTime?
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  target User @relation("SanctionTarget", fields: [targetId], references: [id])
  issuer User @relation("SanctionIssuer", fields: [issuerId], references: [id])
}

model Ticket {
  id         String         @id @default(cuid())
  number     Int            @unique @default(autoincrement())
  category   TicketCategory
  status     TicketStatus   @default(OPEN)
  subject    String
  body       String         @db.Text
  creatorId  String
  assigneeId String?
  matchId    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  creator  User   @relation("TicketCreator", fields: [creatorId], references: [id])
  assignee User?  @relation("TicketAssignee", fields: [assigneeId], references: [id])
  match    Match? @relation(fields: [matchId], references: [id])
}

model QueueEntry {
  id        String      @id @default(cuid())
  playerId  String
  status    QueueStatus @default(WAITING)
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([status, joinedAt])
}

model EloHistory {
  id        String   @id @default(cuid())
  playerId  String
  matchId   String?
  oldElo    Int
  newElo    Int
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([createdAt])
}

model ServiceHealth {
  id        String        @id @default(cuid())
  service   String        @unique
  status    ServiceStatus @default(ONLINE)
  message   String?
  updatedAt DateTime      @updatedAt
}
